package-as: JustJunk

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Fetch embedded libraries from their official sources at package time, so
# published builds always ship current versions. The committed copies under
# Libs/ are kept for local in-game testing.
externals:
    Libs/LibStub:
        url: https://repos.wowace.com/wow/libstub/trunk
    Libs/CallbackHandler-1.0:
        url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
    Libs/AceDB-3.0:
        url: https://repos.wowace.com/wow/ace3/trunk/AceDB-3.0
    Libs/AceDBOptions-3.0:
        url: https://repos.wowace.com/wow/ace3/trunk/AceDBOptions-3.0
    Libs/AceConfig-3.0:
        url: https://repos.wowace.com/wow/ace3/trunk/AceConfig-3.0
    Libs/AceGUI-3.0:
        url: https://repos.wowace.com/wow/ace3/trunk/AceGUI-3.0

ignore:
    - .git
    - .github
    - .gitignore
    - .luarc.json
    - .pkgmeta
    - README.md
    - CHANGELOG.md
    - UNRELEASED.md
    - Documentation
    - "*.code-workspace"
    - build.ps1
    - release.ps1
